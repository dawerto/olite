<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondoApp"
    android:orientation="vertical">

    <!-- Cabecera con título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/dancing_script"
        android:text="Catálogo"
        android:textColor="@color/colorLogoNaranja"
        android:textSize="36sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:text="Todos nuestros productos"
        android:textColor="@color/textoSecundario"
        android:textSize="13sp"
        android:textStyle="italic" />

    <!-- Buscador -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:hint="Buscar producto..."
        app:boxStrokeColor="@color/marronTierra"
        app:hintTextColor="@color/marronTierra"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/marronTierra"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/marronTierra" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Mensaje cuando no hay resultados -->
    <TextView
        android:id="@+id/tvSinResultados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:text="No se encontraron productos"
        android:textColor="@color/textoSecundario"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Grid de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="10dp"
        android:paddingBottom="16dp" />

</LinearLayout>