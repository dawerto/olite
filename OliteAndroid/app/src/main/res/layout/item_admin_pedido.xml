<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/blanco"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Cabecera: Nº pedido + badge estado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNumPedido"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/marronTierra"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Pedido #12" />

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/cardGris"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/marronTierra"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="PENDIENTE" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/textoSecundario"
            android:textSize="12sp"
            tools:text="15/04/2026 14:32" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="@color/cardGris" />

        <!-- Productos + total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNumProductos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/marronTierra"
                    android:textSize="13sp"
                    tools:text="3 producto(s)" />

                <TextView
                    android:id="@+id/tvMetodoPago"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/textoSecundario"
                    android:textSize="12sp"
                    tools:text="Pago: Tarjeta" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:textColor="@color/colorLogoNaranja"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="35,80€" />
        </LinearLayout>

        <!-- Pista pulsable -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="Pulsa para cambiar estado →"
            android:textColor="@color/textoSecundario"
            android:textSize="11sp"
            android:textStyle="italic" />
    </LinearLayout>
</androidx.cardview.widget.CardView>