<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondoApp"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Logo Olité con fuente Dancing Script -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/dancing_script"
        android:text="Olité"
        android:textColor="@color/colorLogoNaranja"
        android:textSize="64sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:text="Productos naturales y ecológicos"
        android:textColor="@color/textoSecundario"
        android:textSize="14sp"
        android:textStyle="italic" />

    <!-- Email -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Email"
        app:boxStrokeColor="@color/marronTierra"
        app:hintTextColor="@color/marronTierra"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/marronTierra" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Contraseña -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:hint="Contraseña"
        app:boxStrokeColor="@color/marronTierra"
        app:hintTextColor="@color/marronTierra"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/marronTierra"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/marronTierra" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botón Iniciar sesión - terracota como en el Home -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:text="Iniciar sesión"
        android:textColor="@color/blanco"
        android:textSize="16sp"
        app:backgroundTint="@color/colorLogoNaranja"
        app:cornerRadius="24dp" />

    <!-- Enlace al registro -->
    <TextView
        android:id="@+id/tvRegistro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="¿No tienes cuenta? Regístrate"
        android:textColor="@color/colorLogoNaranja"
        android:textSize="14sp" />

</LinearLayout>